APP_ENV=development
HOST=127.0.0.1
PORT=8000
MAX_UPLOAD_SIZE_MB=25
# Optional: when set, all /api/* routes require this header:
# X-API-Key: <API_ACCESS_KEY>
API_ACCESS_KEY=
# In production, set to false to hide debug-heavy status fields.
STATUS_INCLUDE_DEBUG=true

# Codex / OpenAI-compatible API (recommended primary)
CODEX_API_KEY=your_codex_api_key
# Backward-compatible alias (if you already use GPT_API_KEY):
# GPT_API_KEY=your_codex_api_key
CODEX_BASE_URL=https://api.openai.com/v1
# Text model: use lighter/cheaper tier
CODEX_TEXT_MODEL=gpt-4.1-mini
# Figure model: use stronger generation tier
CODEX_FIGURE_MODEL=gpt-image-1
CODEX_REQUEST_TIMEOUT_SECONDS=30

# IMG / image provider (preferred for figure generation)
IMG_API_KEY=your_img_api_key
# Supports OpenAI-compatible image endpoints and Gemini-compatible image endpoints.
IMG_BASE_URL=https://your-img-gateway.example
IMG_FIGURE_MODEL=your_img_figure_model
IMG_REQUEST_TIMEOUT_SECONDS=30
# Gemini-compatible IMG auth mode: auto | query_only | bearer_only | query_first | bearer_first
IMG_GEMINI_AUTH_MODE=auto

# Google GenAI
GOOGLE_API_KEY=your_google_api_key
GOOGLE_MODEL=models/gemma-3-1b-it
ANALYSIS_MODEL=models/gemma-3-1b-it
MENTOR_MODEL=models/gemma-3-1b-it
DIAGRAM_MODEL=models/gemma-3-1b-it
GOOGLE_USE_SYSTEM_PROXY=false
GOOGLE_PROXY_URL=http://127.0.0.1:7890
GOOGLE_REQUEST_TIMEOUT_SECONDS=6

# OpenRouter (text fallback provider)
OPEN_API_KEY=your_openrouter_api_key
OPEN_MODEL=google/gemini-2.5-flash
OPEN_REQUEST_TIMEOUT_SECONDS=15
TEXT_REQUEST_RETRY_ATTEMPTS=2
TEXT_REQUEST_RETRY_BACKOFF_SECONDS=1.0

# Global routing policy (single-instance deployment)
# Order is comma-separated, and any provider in DISABLE_PROVIDERS is skipped.
TEXT_PROVIDER_ORDER=codex,google,openrouter
FIGURE_PROVIDER_ORDER=img,codex,glm
# JSON map per provider; values can be string or list.
# Example: {"codex":"gpt-4.1-mini","google":["models/gemini-2.5-flash","models/gemma-3-1b-it"],"openrouter":"google/gemini-2.5-flash"}
TEXT_MODEL_MAP={}
# Example: {"img":"gemini-2.5-flash-image-preview","codex":"gpt-image-1","glm":"cogview-3-plus"}
FIGURE_MODEL_MAP={}
DISABLE_PROVIDERS=

# GLM / ZhipuAI
GLM_API_KEY=your_glm_api_key
GLM_MODEL=glm-4v-flash
FIGURE_MODEL=cogview-3-plus
GLM_PROXY_URL=http://127.0.0.1:7890
GLM_REQUEST_TIMEOUT_SECONDS=30

# Recommended routing:
# - Figure generation: IMG first, then Codex/OpenAI-compatible API, then GLM fallback
# - Text generation: Codex first; otherwise Google/OpenRouter fallback
ENABLE_VECTOR_STORE=true
# When true, PDFs under data_dir are indexed in the background on server start.
AUTO_INGEST_ON_STARTUP=true

# Embeddings / local storage
EMBEDDINGS_MODEL=all-MiniLM-L6-v2
