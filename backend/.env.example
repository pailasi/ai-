# =============================================================================
# Sci-Copilot — 环境变量示例（复制为 .env 后按需填写）
# =============================================================================
#
# 怎么用（给从 GitHub clone 的同学）
#   1. cd backend
#   2. cp .env.example .env     Windows: copy .env.example .env
#   3. 用编辑器打开 .env，至少配置「文本模型」或「配图」其一相关密钥（见下方说明）
#   4. python main.py           浏览器打开 http://127.0.0.1:8000
#
# 注意
#   - .env 已在 .gitignore 中，不要提交真实密钥。
#   - 加载顺序：先读本文件默认值，再由同目录 .env 覆盖（见 config.py）。
#   - 布尔值：true / false（小写）。JSON 字段请写在一行内，例如 TEXT_MODEL_MAP={}
#
# -----------------------------------------------------------------------------
# 最小配置思路（任选一条主链路即可跑起来）
# -----------------------------------------------------------------------------
#
# A) 只用 OpenAI 兼容 API（推荐，一条 key 同时覆盖对话 / 导师规划 / 写作等文本）
#    → 填 CODEX_API_KEY（或别名 GPT_API_KEY，二选一即可，代码会读）
#
# B) 只用 Google Gemini（走 google 通道）
#    → 填 GOOGLE_API_KEY；可选 ANALYSIS_MODEL 指定对话用模型名
#
# C) 文本兜底 OpenRouter
#    → 填 OPEN_API_KEY；当 codex、google 都不可用时参与 TEXT_PROVIDER_ORDER 链
#
# 配图（/api/figure）是另一条链：默认顺序 img → codex → glm
#    → 优先配 IMG_*；不配则尝试用 CODEX_FIGURE_MODEL 生图；再不行可走 GLM
#
# =============================================================================

# -----------------------------------------------------------------------------
# 1. 应用与 HTTP
# -----------------------------------------------------------------------------
APP_ENV=development
HOST=127.0.0.1
PORT=8000
API_PREFIX=/api

# 上传 PDF 单文件大小上限（MB）
MAX_UPLOAD_SIZE_MB=25

# 可选：非空时，所有 /api/* 请求须带头 X-API-Key: <与你填写相同的值>
API_ACCESS_KEY=

# 开发环境可在 /api/status 里看到较多调试字段；生产建议 false
STATUS_INCLUDE_DEBUG=true

# 浏览器跨域：JSON 数组字符串。默认已含本机 8000 端口页面
# CORS_ORIGINS=["http://127.0.0.1:8000","http://localhost:8000"]

# -----------------------------------------------------------------------------
# 2. OpenAI 兼容 API（Codex 通道 — 文本 + 可选生图）
# -----------------------------------------------------------------------------
# 官方 OpenAI、Azure OpenAI、One API、New API 等只要兼容 /v1/chat/completions 即可
CODEX_API_KEY=
CODEX_BASE_URL=https://api.openai.com/v1

# 与旧文档兼容的别名（未设置 CODEX_API_KEY 时会读这个）
# GPT_API_KEY=
# GPT_BASE_URL=https://api.openai.com/v1

CODEX_TEXT_MODEL=gpt-4.1-mini
CODEX_FIGURE_MODEL=gpt-image-1
CODEX_REQUEST_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# 3. 独立配图网关（IMG 通道 — 优先用于 /api/figure）
# -----------------------------------------------------------------------------
# 填了 IMG_API_KEY 且排在 FIGURE_PROVIDER_ORDER 前面时，会走该网关。
# 具体 URL / 模型名取决于你的供应商文档。
IMG_API_KEY=
IMG_BASE_URL=
IMG_FIGURE_MODEL=
IMG_REQUEST_TIMEOUT_SECONDS=30
# Gemini 系网关鉴权策略：auto | query_only | bearer_only | query_first | bearer_first
IMG_GEMINI_AUTH_MODE=auto

# -----------------------------------------------------------------------------
# 4. Google GenAI（google 通道 — 文本 / 部分嵌入逻辑）
# -----------------------------------------------------------------------------
GOOGLE_API_KEY=
GOOGLE_MODEL=models/gemma-3-1b-it

# 对话、分析、示意图文案等优先使用的「Google 系模型名」；留空则由路由与 codex 模型推导
ANALYSIS_MODEL=
DIAGRAM_MODEL=

GOOGLE_USE_SYSTEM_PROXY=false
GOOGLE_PROXY_URL=
GOOGLE_REQUEST_TIMEOUT_SECONDS=6

# -----------------------------------------------------------------------------
# 5. OpenRouter（openrouter 通道 — 文本兜底）
# -----------------------------------------------------------------------------
OPEN_API_KEY=
OPEN_MODEL=google/gemini-2.5-flash
OPEN_REQUEST_TIMEOUT_SECONDS=15

TEXT_REQUEST_RETRY_ATTEMPTS=2
TEXT_REQUEST_RETRY_BACKOFF_SECONDS=1.0

# -----------------------------------------------------------------------------
# 6. 智谱 GLM（glm 通道 — 文本 / 配图兜底）
# -----------------------------------------------------------------------------
GLM_API_KEY=
GLM_MODEL=glm-4v-flash
# 与配图相关的 GLM 侧模型名（当 FIGURE_PROVIDER_ORDER 含 glm 时使用）
FIGURE_MODEL=cogview-3-plus
GLM_PROXY_URL=
GLM_REQUEST_TIMEOUT_SECONDS=30

# -----------------------------------------------------------------------------
# 7. 全局路由（逗号分隔 provider id）
# -----------------------------------------------------------------------------
# 文本：codex | google | openrouter
TEXT_PROVIDER_ORDER=codex,google,openrouter
# 配图：img | codex | glm
FIGURE_PROVIDER_ORDER=img,codex,glm

# 按 provider 覆盖模型名，JSON 对象，键为 provider。值可为字符串或字符串数组（多候选）
# 示例（勿换行）：TEXT_MODEL_MAP={"codex":"gpt-4.1-mini","google":["models/gemini-2.5-flash","models/gemma-3-1b-it"]}
TEXT_MODEL_MAP={}
FIGURE_MODEL_MAP={}

# 临时禁用某些 provider，逗号分隔，例如：codex,img
DISABLE_PROVIDERS=

# -----------------------------------------------------------------------------
# 8. 知识库与本地目录（一般保持默认即可）
# -----------------------------------------------------------------------------
ENABLE_VECTOR_STORE=true
AUTO_INGEST_ON_STARTUP=true
EMBEDDINGS_MODEL=all-MiniLM-L6-v2

# 以下为可选绝对/相对路径；不填则使用 backend 目录下的默认子目录
# DATA_DIR=
# DIAGRAM_DIR=
# FIGURE_DIR=
# CHROMA_DIR=
